# ── LLM Configuration ──────────────────────────────────────
# Leave OPENAI_API_KEY empty to use fallback (template) reports
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Embedding ─────────────────────────────────────────────
EMBEDDING_BACKEND=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Storage Paths ─────────────────────────────────────────
# For Docker: paths are relative to /app inside the container
# For local dev: paths are relative to project root
DATA_DIR=./data
INDEX_DIR=./storage/index
UPLOAD_DIR=./data/uploads
KB_STORAGE_DIR=./storage/kbs

# ── Vector Store ──────────────────────────────────────────
VECTOR_BACKEND=simple
CHROMA_COLLECTION=esg_documents
MILVUS_URI=./storage/milvus_esg.db
MILVUS_COLLECTION=esg_documents

# ── RAG Parameters ────────────────────────────────────────
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=6
MAX_CONTEXT_CHUNKS=8
RETRIEVAL_CANDIDATE_MULTIPLIER=4

# ── Docker-specific (only used by docker-compose) ────────
# PORT=8001
# WORKERS=1
# LOG_LEVEL=info
